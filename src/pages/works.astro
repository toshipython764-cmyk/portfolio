---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
    {
        title: "Enterprise Data Pipeline",
        category: "PYTHON / DATA ENGINEERING",
        description: "社内のサイロ化されたデータを統合・可視化し、レポーティング工数を月間200時間削減。",
        color: "var(--acc-cyan)",
        bg: "linear-gradient(135deg, rgba(0, 229, 255, 0.15) 0%, rgba(10, 15, 28, 1) 100%)"
    },
    {
        title: "Corporate UX Redesign",
        category: "FRONT-END / DX",
        description: "AstroとGSAPを用いたパフォーマンス特化のコーポレートサイト刷新。表示速度を400%改善。",
        color: "var(--acc-gold)",
        bg: "linear-gradient(135deg, rgba(240, 165, 0, 0.15) 0%, rgba(10, 15, 28, 1) 100%)"
    },
    {
        title: "AI Chat Assistant",
        category: "PYTHON / LLM",
        description: "OpenAI APIを活用した社内向けナレッジ検索ボット。社内ドキュメントを一元的にRAG構成で検索。",
        color: "var(--acc-cyan)",
        bg: "linear-gradient(135deg, rgba(0, 229, 255, 0.15) 0%, rgba(10, 15, 28, 1) 100%)"
    },
    {
        title: "Workflow Automation",
        category: "BUSINESS ARCHITECTURE",
        description: "アナログな承認フローを完全にデジタル化。要件定義からシステム導入、現場への定着支援まで伴走。",
        color: "var(--acc-gold)",
        bg: "linear-gradient(135deg, rgba(240, 165, 0, 0.15) 0%, rgba(10, 15, 28, 1) 100%)"
    }
];
---

<BaseLayout title="Works">
    <!-- Three.js Visual Network Background -->
    <canvas id="works-webgl-canvas" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 0; pointer-events: none;"></canvas>

    <div class="pt-32 pb-20 px-6 max-w-7xl mx-auto min-h-screen relative z-10" id="works-container">
        
        <!-- Animated Background Glow -->
        <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 140vw; height: 140vh; background: radial-gradient(circle at 35% 45%, rgba(0,229,255,0.06) 0%, transparent 50%), radial-gradient(circle at 65% 55%, rgba(240,165,0,0.04) 0%, transparent 50%); pointer-events: none; z-index: -1;"></div>

        <!-- SVG Filters for Distortion (Hidden but active) -->
        <svg xmlns="http://www.w3.org/2000/svg" style="position: absolute; width: 0; height: 0; pointer-events: none; z-index: -1;">
            <defs>
                {projects.map((_, i) => (
                    <filter id={`distortion-filter-${i}`}>
                        <feTurbulence type="fractalNoise" baseFrequency="0.02 0.05" numOctaves="2" result="noise" />
                        <feDisplacementMap in="SourceGraphic" in2="noise" scale="0" xChannelSelector="R" yChannelSelector="G" id={`displacement-map-${i}`} />
                    </filter>
                ))}
            </defs>
        </svg>

        <header class="mb-24 text-center relative z-10" style="margin-top: 6rem;">
            <h1 class="outfit font-extrabold text-4xl md:text-6xl tracking-tight scroll-reveal" style="color: var(--text-primary); text-shadow: 0 4px 12px rgba(0,229,255,0.1);">
                SELECTED <span style="color: var(--acc-gold);">WORKS</span>
            </h1>
            <p class="text-sm md:text-base font-medium scroll-reveal delay-1" style="color: var(--text-secondary); margin-top: 4rem;">
                技術とビジネスの交差点。これまでの軌跡と実績。（準備中・プレースホルダー）
            </p>
        </header>

        <div class="grid md:grid-cols-2 gap-10 relative z-10 pl-2 pr-2">
            {projects.map((project, i) => (
                <article class="work-card relative overflow-hidden aspect-video cursor-pointer scroll-reveal glass-card flex flex-col items-center justify-center text-center" data-index={i} style="background-color: var(--bg-surface); border: 1px solid rgba(148, 163, 184, 0.15); border-radius: 2.5rem;">
                    
                    <!-- Background Visual (Distortion Target) -->
                    <div class="work-bg absolute inset-0 origin-center" 
                         style={`background: ${project.bg}; filter: url(#distortion-filter-${i}); transform: scale(1.05);`}>
                        <div class="absolute inset-0 opacity-15" style="background-image: radial-gradient(rgba(248,250,252,0.8) 1px, transparent 1px); background-size: 24px 24px;"></div>
                    </div>
                    
                    <!-- Glare / Overlay -->
                    <div class="work-overlay absolute inset-0 opacity-90 transition-opacity duration-700" style="background: linear-gradient(to top, rgba(10,15,28,0.95) 5%, transparent 80%); pointer-events: none;"></div>

                    <!-- Content, perfectly centered vertically and horizontally -->
                    <div class="work-content absolute inset-0 z-10 w-full h-full flex flex-col items-center justify-center text-center p-8 transition-transform duration-500" style="transform: translateY(0) translateZ(0);">
                        <span class="outfit font-bold tracking-widest text-xs mb-3 block work-category text-center" style={`color: ${project.color};`}>{project.category}</span>
                        <h3 class="outfit text-2xl md:text-3xl font-extrabold mb-3 line-clamp-2 text-center" style="color: var(--text-primary); text-shadow: 0 4px 12px rgba(0,0,0,0.6);">{project.title}</h3>
                        <div class="work-desc opacity-0 text-center w-full flex flex-col items-center" style="transform: translateY(10px);">
                            <p class="text-sm md:text-base leading-relaxed max-w-sm mx-auto text-center" style="color: var(--text-secondary); text-shadow: 0 2px 4px rgba(0,0,0,0.8);">{project.description}</p>
                            <div class="mt-5 flex items-center justify-center gap-2 outfit text-xs font-bold tracking-wide uppercase" style={`color: ${project.color};`}>
                               View Case Study 
                               <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </div>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </div>
</BaseLayout>

<style>
    .aspect-video { aspect-ratio: 16 / 9; }
    .grid { display: grid; }
    .gap-10 { gap: 2.5rem; }
    .origin-center { transform-origin: center; }
    .pl-2 { padding-left: 0.5rem; }
    .pr-2 { padding-right: 0.5rem; }
    .flex { display: flex; }
    .flex-col { flex-direction: column; }
    .items-center { align-items: center; }
    .justify-center { justify-content: center; }
    .max-w-sm { max-width: 24rem; }
    
    .glass-card {
        box-shadow: 0 15px 35px -10px rgba(0, 0, 0, 0.6);
        transition: box-shadow 0.4s ease;
    }
    .work-card:hover {
        /* Additional shadow to reinforce floating effect */
        box-shadow: 0 40px 70px -15px rgba(0, 0, 0, 0.95), inset 0 1px 0 rgba(255, 255, 255, 0.1);
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }

    @media (min-width: 768px) {
        .md\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
</style>

<script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import * as THREE from 'three';

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener('astro:page-load', () => {
        // --- 1. GSAP Scroll Reveal & Hover Effects ---
        const reveals = document.querySelectorAll('.scroll-reveal');
        reveals.forEach((el) => {
            gsap.fromTo(el, 
                { y: 40, opacity: 0 },
                {
                    y: 0, opacity: 1, duration: 1, ease: 'power3.out',
                    scrollTrigger: {
                        trigger: el, start: 'top 85%'
                    }
                }
            );
        });

        const cards = document.querySelectorAll('.work-card');
        cards.forEach((card) => {
            const index = card.getAttribute('data-index');
            const map = document.querySelector(`#displacement-map-${index}`);
            const bg = card.querySelector('.work-bg');
            const overlay = card.querySelector('.work-overlay');
            const content = card.querySelector('.work-content');
            const desc = card.querySelector('.work-desc');
            const category = card.querySelector('.work-category');

            const hoverTl = gsap.timeline({ paused: true });
            
            if(map) {
                hoverTl.to(map, { attr: { scale: 40 }, duration: 0.3, ease: "power2.out" }, 0)
                       .to(map, { attr: { scale: 5 }, duration: 0.5, ease: "power1.inOut" }, 0.3);
            }
            
            hoverTl.to(bg, { scale: 1.15, duration: 0.8, ease: "power3.out" }, 0)
                   .to(overlay, { opacity: 0.2, duration: 0.4, ease: "power2.out" }, 0)
                   // Relative hover movement: Shift the fully centered container slightly UP
                   .to(content, { y: -15, duration: 0.5, ease: "power3.out" }, 0)
                   .to(desc, { opacity: 1, y: 0, duration: 0.4, ease: "power2.out" }, 0.1)
                   .to(category, { letterSpacing: "0.25em", duration: 0.4, ease: "power2.out" }, 0);

            card.addEventListener('mouseenter', () => hoverTl.play());
            card.addEventListener('mouseleave', () => hoverTl.reverse());
        });

        // --- 2. Three.js Extremely Dense Network Background ---
        const canvas = document.getElementById('works-webgl-canvas') as HTMLCanvasElement;
        if(!canvas) return;

        if((window as any).worksRenderer) {
            (window as any).worksRenderer.dispose();
            cancelAnimationFrame((window as any).worksAnimationFrameId);
        }

        const scene = new THREE.Scene();
        scene.fog = new THREE.FogExp2(0x0a0f1c, 0.015);

        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
        (window as any).worksRenderer = renderer;
        
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(window.innerWidth, window.innerHeight);
        camera.position.z = 30;

        const group = new THREE.Group();
        scene.add(group);

        const geoCyan = new THREE.OctahedronGeometry(1.5, 0);
        const geoGold = new THREE.TorusGeometry(1.4, 0.3, 8, 4);
        
        const matCyan = new THREE.MeshBasicMaterial({ color: 0x00E5FF, wireframe: true, transparent: true, opacity: 0.08 });
        const matGold = new THREE.MeshBasicMaterial({ color: 0xF0A500, wireframe: true, transparent: true, opacity: 0.06 });

        const nodes: THREE.Mesh[] = [];
        // Increased node count drastically to 450
        for(let i=0; i<450; i++) {
            const isCyan = Math.random() > 0.3;
            const meshScale = Math.random() * 0.5 + 0.2; 
            const mesh = new THREE.Mesh(isCyan ? geoCyan : geoGold, isCyan ? matCyan : matGold);
            mesh.position.set(
                (Math.random() - 0.5) * 120, 
                (Math.random() - 0.5) * 120,
                (Math.random() - 0.5) * 60 - 5
            );
            mesh.scale.set(meshScale, meshScale, meshScale);
            mesh.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, Math.random() * Math.PI);
            
            // Very fast float speeds
            (mesh as any).floatSpeedX = (Math.random() - 0.5) * 0.015;
            (mesh as any).floatSpeedY = (Math.random() - 0.5) * 0.015;
            (mesh as any).rotSpeed = (Math.random() - 0.5) * 0.02;

            group.add(mesh);
            nodes.push(mesh);
        }

        // Live updating network lines connecting geometries
        const lineMat = new THREE.LineBasicMaterial({ color: 0x00E5FF, transparent: true, opacity: 0.05 });
        const lineGeo = new THREE.BufferGeometry();
        // Allocate up to 4 max connections per node
        const maxLines = nodes.length * 4;
        const positions = new Float32Array(maxLines * 6);
        lineGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        const lines = new THREE.LineSegments(lineGeo, lineMat);
        group.add(lines);

        let mouseX = 0; let mouseY = 0;
        let targetX = 0; let targetY = 0;

        const handleMouseMove = (e: MouseEvent) => {
            mouseX = (e.clientX - window.innerWidth / 2);
            mouseY = (e.clientY - window.innerHeight / 2);
        };
        document.addEventListener('mousemove', handleMouseMove);

        const animate = () => {
            (window as any).worksAnimationFrameId = requestAnimationFrame(animate);
            targetX = mouseX * 0.0015;
            targetY = mouseY * 0.0015;

            // Highly responsive parallax movement
            group.position.x += 0.1 * (-targetX - group.position.x);
            group.position.y += 0.1 * (targetY - group.position.y);
            group.rotation.x += 0.001;
            group.rotation.y += 0.003;
            
            // Fast floating application
            nodes.forEach(node => {
                node.position.x += Math.sin(Date.now() * 0.003) * (node as any).floatSpeedX;
                node.position.y += Math.cos(Date.now() * 0.003) * (node as any).floatSpeedY;
                node.rotation.x += (node as any).rotSpeed;
                node.rotation.y += (node as any).rotSpeed;
            });

            // Dynamically recalculate lines 
            const posAttr = lines.geometry.attributes.position.array as Float32Array;
            let idx = 0;
            for(let i=0; i<nodes.length; i++) {
                let connections = 0;
                for(let j=i+1; j<nodes.length; j++) {
                    if(nodes[i].position.distanceTo(nodes[j].position) < 18 && connections < 4) {
                        posAttr[idx++] = nodes[i].position.x;
                        posAttr[idx++] = nodes[i].position.y;
                        posAttr[idx++] = nodes[i].position.z;
                        posAttr[idx++] = nodes[j].position.x;
                        posAttr[idx++] = nodes[j].position.y;
                        posAttr[idx++] = nodes[j].position.z;
                        connections++;
                    }
                }
            }
            lines.geometry.setDrawRange(0, idx / 3);
            lines.geometry.attributes.position.needsUpdate = true;

            renderer.render(scene, camera);
        };
        animate();

        const handleResize = () => {
            if(!renderer) return;
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        };
        window.addEventListener('resize', handleResize);

        // Cleanup
        document.addEventListener('astro:before-swap', () => {
            cancelAnimationFrame((window as any).worksAnimationFrameId);
            window.removeEventListener('resize', handleResize);
            document.removeEventListener('mousemove', handleMouseMove);
        }, { once: true });
    });
</script>
