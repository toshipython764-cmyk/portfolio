---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
    <section class="h-screen flex items-center justify-center relative overflow-hidden" id="hero-section">
        <!-- 3D Canvas specific to hero section -->
        <canvas id="webgl-canvas"></canvas>

        <div class="z-10 text-center px-6">
            <h1 class="outfit font-extrabold text-5xl md:text-8xl tracking-tight mb-4 split-text" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5);">
                ENGINEERING<br>
                <span style="color: var(--acc-cyan);">&amp;</span> BUSINESS
            </h1>
            <p class="text-lg mt-6 font-semibold delay-fade outfit tracking-widest" style="color: var(--acc-gold);">
                Toshiki Hamakawa
            </p>
            <p class="mt-4 delay-fade" style="max-width: 42rem; margin-inline: auto; color: var(--text-secondary); line-height: 1.8;">
                自動車メーカーでのDX推進経験と7年間のビジネスパーソンとしての土台。<br>
                ただコードを書くだけではない、<span style="color: var(--text-primary); font-weight: bold;">「任せて安心できる」</span>開発パートナーとして。
            </p>
            
            <div class="mt-12 delay-fade">
                <a href="/business-skills" class="inline-flex items-center gap-2 pb-1 border-b-2" style="border-color: var(--acc-cyan); color: var(--text-primary); transition: opacity 0.3s;" onmouseover="this.style.opacity='0.6'" onmouseout="this.style.opacity='1'">
                    <span class="outfit tracking-widest font-semibold uppercase text-sm">Explore My Skills</span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </a>
            </div>
        </div>
    </section>
</BaseLayout>

<script>
    import gsap from 'gsap';
    import * as THREE from 'three';

    let renderer: THREE.WebGLRenderer | null = null;
    let animationFrameId: number;

    document.addEventListener('astro:page-load', () => {
        // --- GSAP Typography Animation ---
        const tl = gsap.timeline();
        
        tl.fromTo('.split-text', 
            { y: 80, opacity: 0 },
            { y: 0, opacity: 1, duration: 1.2, ease: "power4.out" }
        );
        
        tl.fromTo('.delay-fade', 
            { y: 30, opacity: 0 },
            { y: 0, opacity: 1, duration: 1, stagger: 0.2, ease: "power3.out" },
            "-=0.6"
        );

        // --- Three.js Interactive Background ---
        const canvas = document.getElementById('webgl-canvas') as HTMLCanvasElement;
        if(!canvas) return;

        // Cleanup previous instance if re-loaded via ViewTransitions
        if(renderer) {
            renderer.dispose();
            cancelAnimationFrame(animationFrameId);
        }

        const scene = new THREE.Scene();
        scene.fog = new THREE.FogExp2(0x0a0f1c, 0.002);

        const parent = canvas.parentElement;
        const width = parent?.clientWidth || window.innerWidth;
        const height = parent?.clientHeight || window.innerHeight;

        const camera = new THREE.PerspectiveCamera(75, width / height, 0.1, 1000);
        renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
        
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(width, height);
        camera.position.z = 30;

        // Create geometric particles (Icosahedron for tech feel)
        const geometry = new THREE.IcosahedronGeometry(1, 0);
        const material = new THREE.MeshBasicMaterial({ 
            color: 0x00E5FF, 
            wireframe: true,
            transparent: true,
            opacity: 0.15
        });

        const particles = new THREE.Group();
        for(let i=0; i<80; i++) {
            const mesh = new THREE.Mesh(geometry, material);
            mesh.position.x = (Math.random() - 0.5) * 100;
            mesh.position.y = (Math.random() - 0.5) * 100;
            mesh.position.z = (Math.random() - 0.5) * 50;
            mesh.rotation.x = Math.random() * Math.PI;
            mesh.rotation.y = Math.random() * Math.PI;
            
            const scale = Math.random() * 2 + 0.5;
            mesh.scale.set(scale, scale, scale);
            
            particles.add(mesh);
        }
        scene.add(particles);

        // Golden dust particles
        const pointGeo = new THREE.BufferGeometry();
        const pointCount = 150;
        const positions = new Float32Array(pointCount * 3);
        for(let i=0; i<pointCount*3; i++) {
            positions[i] = (Math.random() - 0.5) * 120;
        }
        pointGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        const pointMat = new THREE.PointsMaterial({
            color: 0xF0A500,
            size: 0.2,
            transparent: true,
            opacity: 0.6
        });
        const points = new THREE.Points(pointGeo, pointMat);
        scene.add(points);

        // Mouse tracking setup
        let mouseX = 0;
        let mouseY = 0;
        let targetX = 0;
        let targetY = 0;

        const handleMouseMove = (event: MouseEvent) => {
            mouseX = (event.clientX - width / 2);
            mouseY = (event.clientY - height / 2);
        };
        
        document.addEventListener('mousemove', handleMouseMove);

        // Animation Loop
        const clock = new THREE.Clock();
        const animate = () => {
            animationFrameId = requestAnimationFrame(animate);
            const time = clock.getElapsedTime();

            // Smooth interpolation
            targetX = mouseX * 0.001;
            targetY = mouseY * 0.001;

            particles.rotation.y += 0.02 * (targetX - particles.rotation.y);
            particles.rotation.x += 0.02 * (targetY - particles.rotation.x);
            
            // Continuous auto-rotation
            particles.rotation.y += 0.001;

            points.rotation.y = time * 0.05;
            points.rotation.x = time * 0.02;

            if(renderer) renderer.render(scene, camera);
        };
        
        animate();

        // Handle Resize
        const handleResize = () => {
            if(!parent || !renderer) return;
            camera.aspect = parent.clientWidth / parent.clientHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(parent.clientWidth, parent.clientHeight);
        };
        window.addEventListener('resize', handleResize);

        // Cleanup on page transitions
        document.addEventListener('astro:before-swap', () => {
            cancelAnimationFrame(animationFrameId);
            window.removeEventListener('resize', handleResize);
            document.removeEventListener('mousemove', handleMouseMove);
        }, { once: true });
    });
</script>

<style>
    /* Specific styling for Top Page adjustments */
    @media (min-width: 768px) {
        .md\:text-8xl {
            font-size: 5.5rem;
            line-height: 1.1;
        }
    }
</style>
